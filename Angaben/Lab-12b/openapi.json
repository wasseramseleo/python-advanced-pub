{
  "openapi": "3.0.0",
  "info": {
    "title": "Banking App API",
    "version": "1.0.0",
    "description": "API für die Kontoverwaltung und Transaktionen"
  },
  "servers": [
    {
      "url": "http://127.0.0.1:5000",
      "description": "Lokaler Entwicklungs-Server"
    }
  ],
  "paths": {
    "/api/account/{account_id}": {
      "get": {
        "summary": "Kontodetails abrufen",
        "parameters": [
          {
            "name": "account_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Erfolgreich",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Account" }
              }
            }
          },
          "404": { "description": "Konto nicht gefunden" }
        }
      }
    },
    "/api/account/{account_id}/transact": {
      "post": {
        "summary": "Transaktion durchführen",
        "parameters": [
          {
            "name": "account_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/Transaction" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Transaktion erfolgreich",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TransactionResponse" }
              }
            }
          },
          "400": { "description": "Ungültiger Betrag oder unzureichende Deckung" }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Account": {
        "type": "object",
        "properties": {
          "owner": { "type": "string" },
          "balance": { "type": "number" },
          "currency": { "type": "string" }
        }
      },
      "Transaction": {
        "type": "object",
        "required": ["type", "amount"],
        "properties": {
          "type": { "type": "string", "enum": ["DEPOSIT", "WITHDRAW"] },
          "amount": { "type": "number", "minimum": 0.01 }
        }
      },
      "TransactionResponse": {
        "type": "object",
        "properties": {
          "message": { "type": "string" },
          "account_id": { "type": "string" },
          "new_balance": { "type": "number" }
        }
      }
    }
  }
}